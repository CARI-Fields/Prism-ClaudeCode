# ── Experiment data (large; regenerate via the harness / `make analyze`) ──
# Anchored to the analysis data dir so it never matches incidental `data/`
# dirs elsewhere in the tree (e.g. web/app/src/data/).
/analysis/data/

# Live workspace scratch dirs — regenerated, not tracked
/experiment/tasks/*/workspace/

# Generated analysis reports — report.html inlines the FULL dataset + per-request
# context texts, so it must not be committed (esp. on a public repo). Regenerate
# via `make analyze`. figures/ (aggregate charts, no raw text) stay committed.
/analysis/reports/

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
.ipynb_checkpoints/
*.egg-info/
.pytest_cache/

# ── OS / editor ──
.DS_Store
*.swp

# ── Redis artifacts ──
*.rdb

# ── Archives ──
*.zip

# ── Local secrets ──
.env
.env.local
