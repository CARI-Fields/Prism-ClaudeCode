# Copy this file to `.env` and fill in the values you need.
# `.env` is gitignored — never commit real secrets.
# `make analyze` auto-loads `.env`; for other targets (e.g. deploy-space),
# source it first:  set -a; . ./.env; set +a

# HuggingFace — push processed parquet to the private dataset the Space pulls
# from (scripts/push_data.py) and deploy the Space (`make deploy-space`).
# HF_DATASET_REPO is the dataset id (not a secret); same value as the Space's
# HF_DATASET_REPO secret. Find it in the HF Space → Settings → Secrets.
HF_DATASET_REPO=your-namespace/prism-cc-data
HF_ACCESS_TOKEN=

# --- Optional: exact Claude token counts in the context-composition charts ---
# Leave these unset to use the deterministic byte/char estimate (still gives a
# consistent number per block — fixes the system-prompt wobble). Set BOTH to
# fetch real per-block counts from the free `count_tokens` endpoint; results are
# cached in analysis/data/processed/token_cache.json and reused on later builds.
CC_COUNT_TOKENS=1
ANTHROPIC_API_KEY=
